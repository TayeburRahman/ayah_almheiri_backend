{
  "info": {
    "name": "Ayah Almheiri Backend API",
    "_postman_id": "ayah-almheiri-backend-api",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Customer & Shop Owner registration + shared auth APIs"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "customerEmail", "value": "customer@example.com" },
    { "key": "shopOwnerEmail", "value": "shopowner@example.com" }
  ],
  "item": [
    {
      "name": "Customer Auth",
      "item": [
        {
          "name": "Screen 1 — Register Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Fatima Al Mansoori\",\n  \"email\": \"{{customerEmail}}\",\n  \"phone_number\": \"+971501234567\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\",\n  \"termsAccepted\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/customer/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "customer", "register"]
            }
          }
        },
        {
          "name": "Screen 2 — Verify OTP (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"activation_code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-otp"]
            }
          }
        },
        {
          "name": "Resend OTP (Customer)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/resend-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "resend-otp"]
            }
          }
        }
      ]
    },
    {
      "name": "Shop Owner Auth",
      "item": [
        {
          "name": "Screen 1 — Register Shop Owner",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Khalid Al Hashimi\",\n  \"email\": \"{{shopOwnerEmail}}\",\n  \"phone_number\": \"+971509876543\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\",\n  \"termsAccepted\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/shop-owner/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "shop-owner", "register"]
            }
          }
        },
        {
          "name": "Screen 2 — Verify OTP (Shop Owner)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{shopOwnerEmail}}\",\n  \"activation_code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-otp"]
            }
          }
        },
        {
          "name": "Resend OTP (Shop Owner)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{shopOwnerEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/resend-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "resend-otp"]
            }
          }
        }
      ]
    },
    {
      "name": "Shop Owner Business Setup",
      "item": [
        {
          "name": "Screen 3 — Save Location",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"Al Wahda Mall, Hazza Bin Zayed Street, Abu Dhabi, UAE\",\n  \"lat\": 24.4539,\n  \"lng\": 54.3773\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/shop-owner/location",
              "host": ["{{baseUrl}}"],
              "path": ["shop-owner", "location"]
            }
          }
        },
        {
          "name": "Screen 4 — Business Info (Step 1/3)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shop_name\": \"Qahwa Al Emarat\",\n  \"shop_license_number\": \"AUH-2024-78901\",\n  \"contact_email\": \"info@qahwa-alemarat.ae\",\n  \"contact_phone\": \"+971501112233\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/shop-owner/business/info",
              "host": ["{{baseUrl}}"],
              "path": ["shop-owner", "business", "info"]
            }
          }
        },
        {
          "name": "Screen 5 — Branches (Step 2/3)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branches\": [\n    {\n      \"branch_name\": \"Al Bateen Branch - Abu Dhabi\",\n      \"address\": \"Al Bateen, Corniche Road, Abu Dhabi, UAE\",\n      \"lat\": 24.4631,\n      \"lng\": 54.3347,\n      \"phone_number\": \"+971501112233\",\n      \"availability\": [\n        { \"day\": \"Sunday\", \"open\": \"7:00 AM\", \"close\": \"11:00 PM\", \"isClosed\": false },\n        { \"day\": \"Monday\", \"open\": \"7:00 AM\", \"close\": \"11:00 PM\", \"isClosed\": false },\n        { \"day\": \"Tuesday\", \"open\": \"7:00 AM\", \"close\": \"11:00 PM\", \"isClosed\": false },\n        { \"day\": \"Wednesday\", \"open\": \"7:00 AM\", \"close\": \"11:00 PM\", \"isClosed\": false },\n        { \"day\": \"Thursday\", \"open\": \"7:00 AM\", \"close\": \"12:00 AM\", \"isClosed\": false },\n        { \"day\": \"Friday\", \"open\": \"2:00 PM\", \"close\": \"12:00 AM\", \"isClosed\": false },\n        { \"day\": \"Saturday\", \"open\": \"8:00 AM\", \"close\": \"11:00 PM\", \"isClosed\": false }\n      ],\n      \"applyMenuForAll\": true\n    },\n    {\n      \"branch_name\": \"Downtown Dubai Branch\",\n      \"address\": \"Sheikh Mohammed bin Rashid Blvd, Downtown Dubai, UAE\",\n      \"lat\": 25.1972,\n      \"lng\": 55.2744,\n      \"phone_number\": \"+971504445566\",\n      \"availability\": [\n        { \"day\": \"Sunday\", \"open\": \"6:30 AM\", \"close\": \"10:00 PM\", \"isClosed\": false },\n        { \"day\": \"Monday\", \"open\": \"6:30 AM\", \"close\": \"10:00 PM\", \"isClosed\": false },\n        { \"day\": \"Tuesday\", \"open\": \"6:30 AM\", \"close\": \"10:00 PM\", \"isClosed\": false },\n        { \"day\": \"Wednesday\", \"open\": \"6:30 AM\", \"close\": \"10:00 PM\", \"isClosed\": false },\n        { \"day\": \"Thursday\", \"open\": \"6:30 AM\", \"close\": \"11:00 PM\", \"isClosed\": false },\n        { \"day\": \"Friday\", \"open\": \"1:00 PM\", \"close\": \"11:00 PM\", \"isClosed\": false },\n        { \"day\": \"Saturday\", \"open\": \"7:00 AM\", \"close\": \"10:00 PM\", \"isClosed\": false }\n      ],\n      \"applyMenuForAll\": false\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/shop-owner/business/branches",
              "host": ["{{baseUrl}}"],
              "path": ["shop-owner", "business", "branches"]
            }
          }
        },
        {
          "name": "Screen 6 — Documents (Step 3/3)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "business_license",
                  "type": "file",
                  "src": "",
                  "description": "PDF/JPG/PNG, max 5MB"
                },
                {
                  "key": "shop_logo",
                  "type": "file",
                  "src": "",
                  "description": "PDF/JPG/PNG, max 5MB"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/shop-owner/business/documents",
              "host": ["{{baseUrl}}"],
              "path": ["shop-owner", "business", "documents"]
            }
          }
        }
      ]
    },
    {
      "name": "Shared Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "profile"]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"password123\",\n  \"newPassword\": \"newpassword123\",\n  \"confirmPassword\": \"newpassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "change-password"]
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            }
          }
        },
        {
          "name": "Verify Forgot Password OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-forgot-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-forgot-otp"]
            }
          }
        },
        {
          "name": "Resend Forgot Password Code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/resend-forgot-code",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "resend-forgot-code"]
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"newpassword123\",\n  \"confirmPassword\": \"newpassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password?email={{customerEmail}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password"],
              "query": [{ "key": "email", "value": "{{customerEmail}}" }]
            }
          }
        }
      ]
    }
  ]
}
